PORT=5000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY=7d
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Production only: lock CORS to your frontend domain
CLIENT_URL=
